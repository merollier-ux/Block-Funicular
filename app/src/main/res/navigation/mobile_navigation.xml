<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.pythonaudio.pytutor.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_lessons"
        android:name="com.pythonaudio.pytutor.ui.lessons.LessonsFragment"
        android:label="Learn"
        tools:layout="@layout/fragment_lessons" />

    <fragment
        android:id="@+id/navigation_code_lab"
        android:name="com.pythonaudio.pytutor.ui.codelab.CodeLabFragment"
        android:label="Code Lab"
        tools:layout="@layout/fragment_code_lab" />

    <fragment
        android:id="@+id/navigation_tutor"
        android:name="com.pythonaudio.pytutor.ui.tutor.TutorFragment"
        android:label="AI Tutor"
        tools:layout="@layout/fragment_tutor" />

    <action
        android:id="@+id/action_home_to_settings"
        app:destination="@id/navigation_home" />
</navigation>
